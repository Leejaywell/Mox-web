---
import '@/styles/global.css';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
import { localeFromPath } from '@/i18n';
const { title, description } = Astro.props as { title: string; description?: string };
const locale = localeFromPath(Astro.url.pathname);
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const zhHref = new URL(Astro.url.pathname.replace(/^\/en\/?/, '/'), Astro.site).href;
const enPath = Astro.url.pathname.startsWith('/en') ? Astro.url.pathname : '/en' + (Astro.url.pathname === '/' ? '' : Astro.url.pathname);
const enHref = new URL(enPath, Astro.site).href;
---
<!doctype html>
<html lang={locale === 'en' ? 'en' : 'zh'}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="zh" href={zhHref} />
    <link rel="alternate" hreflang="en" href={enHref} />
    <link rel="alternate" hreflang="x-default" href={zhHref} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonical} />
    <meta name="theme-color" content="#0c0a18" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@600&family=Liu+Jian+Mao+Cao&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Nav locale={locale} />
    <main><slot /></main>
    <Footer locale={locale} />
    <script>
      // Scroll-reveal: fade/slide elements in as they enter the viewport, once.
      const io = new IntersectionObserver((entries) => {
        for (const e of entries) {
          if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
        }
      }, { threshold: 0.15 });
      document.querySelectorAll('[data-reveal]').forEach((el) => io.observe(el));
    </script>
  </body>
</html>
