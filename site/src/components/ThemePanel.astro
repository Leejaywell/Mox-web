---
import { getThemes } from '@/data/themes';
import type { Locale } from '@/i18n';
const { locale } = Astro.props as { locale: Locale };
const isEn = locale === 'en';
const themes = getThemes();
const light = themes.filter((t) => !t.dark);
const dark = themes.filter((t) => t.dark);
---
<div id="theme-panel" class="tp" role="dialog" aria-label={isEn ? 'Appearance' : '外观'}>
  <div class="tp-head">{isEn ? 'Appearance' : '外观'}</div>
  <div class="tp-group-label">{isEn ? 'Light' : '浅色'}</div>
  <div class="tp-grid">
    {light.map((th) => (
      <button class="sw" data-theme-id={th.id} title={th.name[locale] ?? th.name.zh} aria-label={th.name[locale] ?? th.name.zh}>
        <span class="chip" style={`background:${th.palette.bg};border-color:${th.palette.accent}`}><i style={`background:${th.palette.accent}`}></i></span>
        <span class="nm">{th.name[locale] ?? th.name.zh}</span>
      </button>
    ))}
  </div>
  <div class="tp-group-label">{isEn ? 'Dark' : '深色'}</div>
  <div class="tp-grid">
    {dark.map((th) => (
      <button class="sw" data-theme-id={th.id} title={th.name[locale] ?? th.name.zh} aria-label={th.name[locale] ?? th.name.zh}>
        <span class="chip" style={`background:${th.palette.bg};border-color:${th.palette.accent}`}><i style={`background:${th.palette.accent}`}></i></span>
        <span class="nm">{th.name[locale] ?? th.name.zh}</span>
      </button>
    ))}
  </div>
</div>

<style>
  .tp { position: fixed; top: 66px; right: 18px; z-index: 60; width: 340px; max-height: 72vh; overflow: auto;
        background: var(--card); border: 1px solid var(--hairline); border-radius: 16px; padding: 16px;
        box-shadow: 0 24px 60px rgba(0,0,0,.22);
        opacity: 0; transform: translateY(-8px) scale(.98); pointer-events: none; transition: opacity .18s ease, transform .18s ease; }
  .tp.open { opacity: 1; transform: none; pointer-events: auto; }
  .tp-head { font-weight: 800; color: var(--fg); margin-bottom: 12px; }
  .tp-group-label { font-size: 12px; letter-spacing: .08em; text-transform: uppercase; color: var(--muted); margin: 12px 0 8px; }
  .tp-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; }
  .sw { background: none; border: none; cursor: pointer; padding: 2px; display: flex; flex-direction: column; align-items: center; gap: 6px; }
  .chip { display: grid; place-items: center; width: 100%; height: 40px; border-radius: 9px; border: 1.5px solid; }
  .chip i { width: 10px; height: 10px; border-radius: 50%; }
  .sw .nm { font-size: 11px; color: var(--muted); white-space: nowrap; }
  .sw:hover .nm { color: var(--fg); }
  .sw.on .chip { box-shadow: 0 0 0 2px var(--card), 0 0 0 4px var(--accent); }
  .sw.on .nm { color: var(--fg); font-weight: 600; }
  @media (max-width: 480px) { .tp { left: 12px; right: 12px; width: auto; } }
</style>
