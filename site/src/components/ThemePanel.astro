---
import { getThemes } from '@/data/themes';
import type { Locale } from '@/i18n';
const { locale } = Astro.props as { locale: Locale };
const isEn = locale === 'en';
const themes = getThemes();
const light = themes.filter((t) => !t.dark);
const dark = themes.filter((t) => t.dark);
---
<div id="theme-panel" class="tp-overlay" role="dialog" aria-modal="true" aria-label={isEn ? 'Appearance' : '外观'}>
  <div class="tp-card">
    <div class="tp-head">{isEn ? 'Appearance' : '外观'}</div>
    <div class="tp-group-label">{isEn ? 'Light' : '浅色'}</div>
    <div class="tp-grid">
      {light.map((th) => (
        <button class="sw" data-theme-id={th.id} title={th.name[locale] ?? th.name.zh} aria-label={th.name[locale] ?? th.name.zh}>
          <span class="chip" style={`background:${th.palette.bg};border-color:${th.palette.accent}`}><i style={`background:${th.palette.accent}`}></i></span>
          <span class="nm">{th.name[locale] ?? th.name.zh}</span>
        </button>
      ))}
    </div>
    <div class="tp-group-label">{isEn ? 'Dark' : '深色'}</div>
    <div class="tp-grid">
      {dark.map((th) => (
        <button class="sw" data-theme-id={th.id} title={th.name[locale] ?? th.name.zh} aria-label={th.name[locale] ?? th.name.zh}>
          <span class="chip" style={`background:${th.palette.bg};border-color:${th.palette.accent}`}><i style={`background:${th.palette.accent}`}></i></span>
          <span class="nm">{th.name[locale] ?? th.name.zh}</span>
        </button>
      ))}
    </div>
  </div>
</div>

<style>
  .tp-overlay { position: fixed; inset: 0; z-index: 60; display: grid; place-items: center;
    background: color-mix(in srgb, #000 42%, transparent); backdrop-filter: blur(3px);
    opacity: 0; pointer-events: none; transition: opacity .2s ease; }
  .tp-overlay.open { opacity: 1; pointer-events: auto; }
  .tp-card { width: min(580px, 92vw); max-height: 82vh; overflow: auto;
    background: var(--card); border: 1px solid var(--hairline); border-radius: 18px; padding: 24px;
    box-shadow: 0 40px 100px rgba(0,0,0,.4); transform: scale(.95); transition: transform .2s ease; }
  .tp-overlay.open .tp-card { transform: none; }
  .tp-head { font-weight: 800; color: var(--fg); font-size: 18px; margin-bottom: 14px; }
  .tp-group-label { font-size: 12px; letter-spacing: .08em; text-transform: uppercase; color: var(--muted); margin: 14px 0 10px; }
  .tp-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 12px; }
  .sw { background: none; border: none; cursor: pointer; padding: 2px; display: flex; flex-direction: column; align-items: center; gap: 6px; }
  .chip { display: grid; place-items: center; width: 100%; height: 44px; border-radius: 10px; border: 1.5px solid; }
  .chip i { width: 11px; height: 11px; border-radius: 50%; }
  .sw .nm { font-size: 11px; color: var(--muted); white-space: nowrap; }
  .sw:hover .nm { color: var(--fg); }
  .sw.on .chip { box-shadow: 0 0 0 2px var(--card), 0 0 0 4px var(--accent); }
  .sw.on .nm { color: var(--fg); font-weight: 600; }
  @media (max-width: 520px) { .tp-grid { grid-template-columns: repeat(4, 1fr); } }
</style>
