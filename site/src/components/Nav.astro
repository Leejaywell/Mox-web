---
import { t, type Locale } from '@/i18n';
import { withBase } from '@/lib/url';
const { locale } = Astro.props as { locale: Locale };
const isEn = locale === 'en';
const home = withBase(isEn ? '/en/' : '/');
// 功能/下载 are sections on the HOME page, so link to home + hash (works from any page).
const features = home + '#features';
const download = home + '#download';
// Trailing slash matters: GitHub Pages 301-redirects `/docs` → `/docs/` and DROPS the
// hash, so `/docs#/zh/faq` lands on the default doc. Link the canonical `/docs/` directly.
const docs = withBase('/docs/') + (isEn ? '#/en/getting-started' : '');
const faq = withBase('/docs/') + (isEn ? '#/en/faq' : '#/zh/faq');
const timeline = withBase(isEn ? '/en/timeline/' : '/timeline/');
const I = {
  features: 'M12 4l1.7 4.3L18 10l-4.3 1.7L12 16l-1.7-4.3L6 10l4.3-1.7z',
  download: 'M12 4v9m0 0l-3.5-3.5M12 13l3.5-3.5M5 18h14',
  docs: 'M7 3h6l4 4v14H7zM13 3v4h4',
  timeline: 'M20 12a8 8 0 11-16 0 8 8 0 0116 0M12 8v4l2.5 1.5',
  faq: 'M20 12a8 8 0 11-16 0 8 8 0 0116 0M9.6 9.2a2.5 2.5 0 113.4 2.3c-.7.4-.9.9-.9 1.6M12 16.4h.01',
};
const links = [
  { href: features, label: t(locale, 'nav.features'), icon: I.features },
  { href: download, label: t(locale, 'nav.download'), icon: I.download },
  { href: docs, label: t(locale, 'nav.docs'), icon: I.docs },
  { href: timeline, label: t(locale, 'nav.timeline'), icon: I.timeline },
  { href: faq, label: t(locale, 'nav.faq'), icon: I.faq },
];
---
<nav class="nav">
  <div class="container nav-inner">
    <a class="brand" href={home} aria-label="Mox">
      <span class="badge" id="nav-mo" aria-hidden="true"></span><span class="word">Mox</span>
    </a>

    <div class="links">
      {links.map((l) => (
        <a href={l.href}>
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={l.icon} /></svg>
          <span>{l.label}</span>
        </a>
      ))}
    </div>

    <div class="right">
      <div class="seg" role="group" aria-label="Language">
        <a class:list={["s", { on: !isEn }]} href={withBase('/')}>中</a>
        <a class:list={["s", { on: isEn }]} href={withBase('/en')}>EN</a>
      </div>
      <button id="theme-open" class="theme-btn" aria-label={t(locale, 'nav.themes')}>
        <svg viewBox="0 0 24 24" width="15" height="15" aria-hidden="true"><path fill="currentColor" d="M12 3a9 9 0 0 0 0 18c.83 0 1.5-.67 1.5-1.5 0-.39-.15-.74-.39-1-.24-.27-.39-.62-.39-1 0-.83.67-1.5 1.5-1.5H16a5 5 0 0 0 5-5c0-4.42-4.03-8-9-8m-5.5 9a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3m3-4a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3m5 0a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3m3 4a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3"/></svg>
        <span>{t(locale, 'nav.themes')}</span>
      </button>
    </div>
  </div>
</nav>
<style>
  .nav { position: sticky; top: 0; z-index: 50; backdrop-filter: blur(12px);
         background: color-mix(in srgb, var(--bg) 82%, transparent);
         border-bottom: 1px solid var(--hairline); }
  .nav-inner { display: flex; align-items: center; gap: 36px; height: 60px; }
  .brand { display: flex; align-items: center; gap: 10px; font-weight: 800; font-size: 19px; color: var(--fg); }
  /* Brand mark: fixed espresso badge holding the animated 墨 (kept stable across themes). */
  .badge { display: grid; place-items: center; width: 32px; height: 32px; border-radius: 9px;
           background: #463524; }
  .badge :global(svg) { width: 26px; height: 26px; }
  .links { display: flex; align-items: center; gap: 22px; font-size: 15px; font-weight: 500; color: var(--text); }
  .links a { display: inline-flex; align-items: center; gap: 6px; }
  .links a svg { color: var(--muted); transition: color .15s ease; }
  .links a:hover { color: var(--fg); }
  .links a:hover svg { color: var(--accent); }
  .right { margin-left: auto; display: flex; align-items: center; gap: 14px; }
  .seg { display: inline-flex; background: color-mix(in srgb, var(--fg) 8%, transparent); border-radius: 999px; padding: 3px; }
  .seg .s { padding: 5px 13px; border-radius: 999px; font-size: 13px; font-weight: 600; color: var(--muted); }
  .seg .s.on { background: var(--card); color: var(--fg); box-shadow: 0 1px 3px rgba(0,0,0,.08); }
  .theme-btn { display: inline-flex; align-items: center; gap: 7px; padding: 7px 15px; border-radius: 999px;
               border: 1px solid var(--hairline); color: var(--fg); font-size: 14px; font-weight: 600;
               background: none; cursor: pointer; font-family: inherit; }
  .theme-btn:hover { background: color-mix(in srgb, var(--fg) 5%, transparent); }
  @media (max-width: 760px) {
    .nav-inner { gap: 16px; }
    .links { display: none; }
    .theme-btn span { display: none; }
    .theme-btn { padding: 7px; }
  }
</style>

<script>
  import HanziWriter from 'hanzi-writer';
  import moData from '@/data/mo-char.json';

  let moTimer: number | undefined;
  function setupNavInk() {
    const target = document.getElementById('nav-mo');
    if (!target || target.dataset.inked) return; // nav is re-rendered per page; guard re-init
    target.dataset.inked = '1';
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const writer = HanziWriter.create(target, '墨', {
      width: 26, height: 26, padding: 1,
      showOutline: false, showCharacter: false,
      strokeColor: '#f3ead8', strokeAnimationSpeed: 2.4, delayBetweenStrokes: 40,
      charDataLoader: (_c: string, onComplete: (d: unknown) => void) => onComplete(moData),
    });
    writer.showCharacter();      // always visible immediately (no blank badge)
    if (!reduce) {
      setTimeout(() => writer.animateCharacter(), 600);
      if (moTimer) clearInterval(moTimer);
      moTimer = window.setInterval(() => writer.animateCharacter(), 9000);
    }
  }
  document.addEventListener('astro:page-load', setupNavInk);
</script>

